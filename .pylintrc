[MASTER]
ignore=node_modules,dist,build,.venv

[MESSAGES CONTROL]
disable=C0303,C0305,C0411,C0415,C0301,R0903,R0902,R0914,W1203,W0707,W0611,W0612,W0613,W0401

[FORMAT]
max-line-length=120

[TYPECHECK]
ignored-modules=dspy,uvicorn,fastapi,numpy,pydantic,optuna,torch,transformers,huggingface_hub,sentence_transformers,faiss,faiss_cpu,chromadb,langchain,langchain_community,unsloth,accelerate,bitsandbytes,pandas,sklearn,xgboost,psycopg2,sqlalchemy,redis,aiohttp,httpx,crewai

[REPORT]
output-format=colorized
