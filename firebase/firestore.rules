rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core Principle: Zero-Trust by default
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Users Collection ---
    // A user can only read and write their EXACT document. Nobody else can enumerate users.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Updates must not tamper with internal KYC or reputation scores
      allow update: if request.auth != null && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['reputation', 'isVerified', 'kycStatus']);
                    
      // Only backend admin SDK can create new verified users via Auth triggers
      allow create: if false;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // --- Listings Collection ---
    // Anyone authenticated can read active listings (typesense replication reads all anyway)
    match /listings/{listingId} {
      allow read: if request.auth != null;
      
      // Creation requires a verifed KYC status
      allow create: if request.auth != null 
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isVerified == true
                    && request.resource.data.lenderId == request.auth.uid;
      
      // Only the lender can update/delete their own listing
      allow update, delete: if request.auth != null 
                            && resource.data.lenderId == request.auth.uid;
    }

    // --- Bookings (Escrow) Collection ---
    // The most critical collection. MITM and IDOR prevention zone.
    match /bookings/{bookingId} {
      // Users can only see bookings they are directly involved in
      allow read: if request.auth != null && (
        resource.data.borrowerId == request.auth.uid || 
        resource.data.lenderId == request.auth.uid
      );
      
      // To create a booking, both parties must be explicitly verified and 
      // the borrowerId payload must strictly match the caller's auth token
      allow create: if request.auth != null 
                    && request.resource.data.borrowerId == request.auth.uid
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isVerified == true;
      
      // Clients CANNOT update escrow or payment statuses directly.
      // This enforces the rule that only Webhooks (Server-side) mutate transaction states.
      allow update: if request.auth != null && (
        resource.data.borrowerId == request.auth.uid || 
        resource.data.lenderId == request.auth.uid
      ) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'escrowAmount', 'paymentIntentId', 'handshakeSignatures']);
      
      allow delete: if false;
    }
  }
}
